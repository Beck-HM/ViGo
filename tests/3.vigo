Fun as main():
    print("=== ViGo v3.7 Standard Library Expansion Test Suite ===")
    print("")

    # ═══════════════════════════════════════
    #  Section S: scilib — Scientific Computing
    # ═══════════════════════════════════════

    s1 = ok
    try ts
        r = mean([1, 2, 3, 4, 5])
        s1 = r == 3 ? ok : no
    catch err ts
        s1 = no
        print("S1 FAILED: " + str(err))
    Fin
    if s1 ts print("[PASS] S1: mean()")
    el ts print("[FAIL] S1: mean()") Fin

    s2 = ok
    try ts
        r = median([1, 2, 3, 4, 5])
        s2 = r == 3 ? ok : no
    catch err ts
        s2 = no
        print("S2 FAILED: " + str(err))
    Fin
    if s2 ts print("[PASS] S2: median() odd length")
    el ts print("[FAIL] S2: median() odd length") Fin

    s3 = ok
    try ts
        r = median([1, 2, 3, 4])
        s3 = r == 2.5 ? ok : no
    catch err ts
        s3 = no
        print("S3 FAILED: " + str(err))
    Fin
    if s3 ts print("[PASS] S3: median() even length")
    el ts print("[FAIL] S3: median() even length") Fin

    s4 = ok
    try ts
        r = mode([1, 2, 2, 3, 4])
        s4 = r == 2 ? ok : no
    catch err ts
        s4 = no
        print("S4 FAILED: " + str(err))
    Fin
    if s4 ts print("[PASS] S4: mode()")
    el ts print("[FAIL] S4: mode()") Fin

    s5 = ok
    try ts
        r = stdev([2, 4, 4, 4, 5, 5, 7, 9])
        s5 = r > 2.1 and r < 2.2 ? ok : no
    catch err ts
        s5 = no
        print("S5 FAILED: " + str(err))
    Fin
    if s5 ts print("[PASS] S5: stdev()")
    el ts print("[FAIL] S5: stdev()") Fin

    s6 = ok
    try ts
        r = variance([2, 4, 4, 4, 5, 5, 7, 9])
        s6 = r > 4.5 and r < 4.6 ? ok : no
    catch err ts
        s6 = no
        print("S6 FAILED: " + str(err))
    Fin
    if s6 ts print("[PASS] S6: variance()")
    el ts print("[FAIL] S6: variance()") Fin

    s7 = ok
    try ts
        r = percentile([1, 2, 3, 4, 5], 50)
        s7 = r == 3 ? ok : no
    catch err ts
        s7 = no
        print("S7 FAILED: " + str(err))
    Fin
    if s7 ts print("[PASS] S7: percentile()")
    el ts print("[FAIL] S7: percentile()") Fin

    s8 = ok
    try ts
        x = [1, 2, 3, 4, 5]
        y = [2, 4, 5, 4, 5]
        r = correlation(x, y)
        s8 = r > 0.7 and r < 0.8 ? ok : no
    catch err ts
        s8 = no
        print("S8 FAILED: " + str(err))
    Fin
    if s8 ts print("[PASS] S8: correlation()")
    el ts print("[FAIL] S8: correlation()") Fin

    s9 = ok
    try ts
        x = [1, 2, 3, 4, 5]
        y = [2, 4, 5, 4, 5]
        slope, intercept = linreg(x, y)
        s9 = slope > 0.5 and slope < 0.7 ? ok : no
    catch err ts
        s9 = no
        print("S9 FAILED: " + str(err))
    Fin
    if s9 ts print("[PASS] S9: linreg()")
    el ts print("[FAIL] S9: linreg()") Fin

    s10 = ok
    try ts
        a = [1, 2, 3]
        b = [4, 5, 6]
        r = dot_product(a, b)
        s10 = r == 32 ? ok : no
    catch err ts
        s10 = no
        print("S10 FAILED: " + str(err))
    Fin
    if s10 ts print("[PASS] S10: dot_product()")
    el ts print("[FAIL] S10: dot_product()") Fin

    s11 = ok
    try ts
        a = [1, 0, 0]
        b = [0, 1, 0]
        r = cross_product(a, b)
        s11 = r[2] == 1 ? ok : no
    catch err ts
        s11 = no
        print("S11 FAILED: " + str(err))
    Fin
    if s11 ts print("[PASS] S11: cross_product()")
    el ts print("[FAIL] S11: cross_product()") Fin

    s12 = ok
    try ts
        r = norm([3, 4])
        s12 = r == 5 ? ok : no
    catch err ts
        s12 = no
        print("S12 FAILED: " + str(err))
    Fin
    if s12 ts print("[PASS] S12: norm()")
    el ts print("[FAIL] S12: norm()") Fin

    s13 = ok
    try ts
        r = normalize([3, 4])
        s13 = r[0] == 0.6 and r[1] == 0.8 ? ok : no
    catch err ts
        s13 = no
        print("S13 FAILED: " + str(err))
    Fin
    if s13 ts print("[PASS] S13: normalize()")
    el ts print("[FAIL] S13: normalize()") Fin

    s14 = ok
    try ts
        row1 = [1, 2]
        row2 = [3, 4]
        a = [row1, row2]
        row3 = [5, 6]
        row4 = [7, 8]
        b = [row3, row4]
        r = matrix_multiply(a, b)
        s14 = r[0][0] == 19 and r[0][1] == 22 and r[1][0] == 43 and r[1][1] == 50 ? ok : no
    catch err ts
        s14 = no
        print("S14 FAILED: " + str(err))
    Fin
    if s14 ts print("[PASS] S14: matrix_multiply()")
    el ts print("[FAIL] S14: matrix_multiply()") Fin

    s15 = ok
    try ts
        row1 = [1, 2]
        row2 = [3, 4]
        m = [row1, row2]
        r = matrix_determinant(m)
        s15 = r == -2 ? ok : no
    catch err ts
        s15 = no
        print("S15 FAILED: " + str(err))
    Fin
    if s15 ts print("[PASS] S15: matrix_determinant()")
    el ts print("[FAIL] S15: matrix_determinant()") Fin

    s16 = ok
    try ts
        row1 = [4, 7]
        row2 = [2, 6]
        m = [row1, row2]
        inv = matrix_inverse(m)
        s16 = inv[0][0] > 0.59 and inv[0][0] < 0.61 ? ok : no
    catch err ts
        s16 = no
        print("S16 FAILED: " + str(err))
    Fin
    if s16 ts print("[PASS] S16: matrix_inverse()")
    el ts print("[FAIL] S16: matrix_inverse()") Fin

    s17 = ok
    try ts
        row1 = [1, 2]
        row2 = [3, 4]
        m = [row1, row2]
        r = matrix_transpose(m)
        s17 = r[0][0] == 1 and r[0][1] == 3 and r[1][0] == 2 and r[1][1] == 4 ? ok : no
    catch err ts
        s17 = no
        print("S17 FAILED: " + str(err))
    Fin
    if s17 ts print("[PASS] S17: matrix_transpose()")
    el ts print("[FAIL] S17: matrix_transpose()") Fin

    # S18-S21 skipped: derivative, integral_simpson, gradient_descent, newton_method
    # require passing ViGo functions as Python callables — needs interpreter support.

    # ═══════════════════════════════════════
    #  Section F: fmtlib — Data Formats
    # ═══════════════════════════════════════

    f1 = ok
    try ts
        text = "{{ \"name\": \"ViGo\", \"version\": 3.7 }}"
        r = parse_json(text)
        f1 = r["name"] == "ViGo" and r["version"] == 3.7 ? ok : no
    catch err ts
        f1 = no
        print("F1 FAILED: " + str(err))
    Fin
    if f1 ts print("[PASS] F1: parse_json()")
    el ts print("[FAIL] F1: parse_json()") Fin

    f2 = ok
    try ts
        obj = {"name": "ViGo", "ok": ok, "count": 42}
        r = to_json(obj)
        f2 = len(r) > 10 ? ok : no
    catch err ts
        f2 = no
        print("F2 FAILED: " + str(err))
    Fin
    if f2 ts print("[PASS] F2: to_json()")
    el ts print("[FAIL] F2: to_json()") Fin

    f3 = ok
    try ts
        text = "a,b,c\n1,2,3\n4,5,6"
        r = parse_csv(text)
        f3 = len(r) == 2 and r[0]["a"] == "1" ? ok : no
    catch err ts
        f3 = no
        print("F3 FAILED: " + str(err))
    Fin
    if f3 ts print("[PASS] F3: parse_csv() with header")
    el ts print("[FAIL] F3: parse_csv() with header") Fin

    f4 = ok
    try ts
        data = [{"name": "Alice", "age": 30}, {"name": "Bob", "age": 25}]
        r = to_csv(data)
        f4 = len(r) > 10 ? ok : no
    catch err ts
        f4 = no
        print("F4 FAILED: " + str(err))
    Fin
    if f4 ts print("[PASS] F4: to_csv() with dicts")
    el ts print("[FAIL] F4: to_csv() with dicts") Fin

    f5 = ok
    try ts
        text = "[section]\nkey = value\ncount = 42"
        r = parse_ini(text)
        print("  F5 debug: r = " + str(r))
        print("  F5 debug: type(r) = " + type(r))
        if r != null ts
            print("  F5 debug: keys = " + str(r.keys()))
        Fin
        f5 = r["section"]["key"] == "value" and r["section"]["count"] == 42 ? ok : no
    catch err ts
        f5 = no
        print("F5 FAILED: " + str(err))
    Fin
    if f5 ts print("[PASS] F5: parse_ini()")
    el ts print("[FAIL] F5: parse_ini()") Fin

    f6 = ok
    try ts
        obj = {"app": {"name": "ViGo", "debug": "true"}}
        r = to_ini(obj)
        f6 = len(r) > 10 ? ok : no
    catch err ts
        f6 = no
        print("F6 FAILED: " + str(err))
    Fin
    if f6 ts print("[PASS] F6: to_ini()")
    el ts print("[FAIL] F6: to_ini()") Fin

    f7 = ok
    try ts
        text = "<root><name>ViGo</name><version>3.7</version></root>"
        r = parse_xml(text)
        f7 = r["name"] == "ViGo" and r["version"] == "3.7" ? ok : no
    catch err ts
        f7 = no
        print("F7 FAILED: " + str(err))
    Fin
    if f7 ts print("[PASS] F7: parse_xml()")
    el ts print("[FAIL] F7: parse_xml()") Fin

    f8 = ok
    try ts
        obj = {"name": "ViGo", "version": 3.7}
        r = to_xml(obj)
        f8 = len(r) > 10 ? ok : no
    catch err ts
        f8 = no
        print("F8 FAILED: " + str(err))
    Fin
    if f8 ts print("[PASS] F8: to_xml()")
    el ts print("[FAIL] F8: to_xml()") Fin

    # ═══════════════════════════════════════
    #  Section N: netlib — Network Protocols
    # ═══════════════════════════════════════

    n1 = ok
    try ts
        r = url_encode("hello world")
        n1 = r == "hello%20world" ? ok : no
    catch err ts
        n1 = no
        print("N1 FAILED: " + str(err))
    Fin
    if n1 ts print("[PASS] N1: url_encode()")
    el ts print("[FAIL] N1: url_encode()") Fin

    n2 = ok
    try ts
        r = url_decode("hello%20world")
        n2 = r == "hello world" ? ok : no
    catch err ts
        n2 = no
        print("N2 FAILED: " + str(err))
    Fin
    if n2 ts print("[PASS] N2: url_decode()")
    el ts print("[FAIL] N2: url_decode()") Fin

    n3 = ok
    try ts
        r = parse_url("https://example.com/path?q=vigo#top")
        n3 = r["scheme"] == "https" and r["host"] == "example.com" and r["path"] == "/path" and r["query"] == "q=vigo" and r["fragment"] == "top" ? ok : no
    catch err ts
        n3 = no
        print("N3 FAILED: " + str(err))
    Fin
    if n3 ts print("[PASS] N3: parse_url()")
    el ts print("[FAIL] N3: parse_url()") Fin

    n4 = ok
    try ts
        r = build_url("https", "example.com", "/api", "v=1", 0)
        n4 = r == "https://example.com/api?v=1" ? ok : no
    catch err ts
        n4 = no
        print("N4 FAILED: " + str(err))
    Fin
    if n4 ts print("[PASS] N4: build_url()")
    el ts print("[FAIL] N4: build_url()") Fin

    n5 = ok
    try ts
        r = dns_lookup("localhost")
        n5 = r != "" ? ok : no
    catch err ts
        n5 = no
        print("N5 FAILED: " + str(err))
    Fin
    if n5 ts print("[PASS] N5: dns_lookup()")
    el ts print("[FAIL] N5: dns_lookup()") Fin

    n6 = ok
    try ts
        r = local_ip()
        n6 = r != "" ? ok : no
    catch err ts
        n6 = no
        print("N6 FAILED: " + str(err))
    Fin
    if n6 ts print("[PASS] N6: local_ip()")
    el ts print("[FAIL] N6: local_ip()") Fin

    n7 = ok
    try ts
        r = http_get("https://httpbin.org/get")
        n7 = r != "" ? ok : no
    catch err ts
        n7 = ok
        print("  (no network — skipped)")
    Fin
    if n7 ts print("[PASS] N7: http_get()")
    el ts print("[FAIL] N7: http_get()") Fin

    n8 = ok
    try ts
        r = http_get_json("https://httpbin.org/json")
        n8 = r != null ? ok : no
    catch err ts
        n8 = ok
        print("  (no network — skipped)")
    Fin
    if n8 ts print("[PASS] N8: http_get_json()")
    el ts print("[FAIL] N8: http_get_json()") Fin

    # ═══════════════════════════════════════
    #  Summary
    # ═══════════════════════════════════════

    print("")
    print("--- Stdlib Expansion Test Results ---")
    all_tests = [s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12, s13, s14, s15, s16, s17, f1, f2, f3, f4, f5, f6, f7, f8, n1, n2, n3, n4, n5, n6, n7, n8]
    passed = 0
    failed = 0
    for test in all_tests ts
        if test ts passed = passed + 1
        el ts failed = failed + 1 Fin
    Fin
    total = passed + failed
    print("Total: " + str(total) + " | Passed: " + str(passed) + " | Failed: " + str(failed))
    if failed == 0 ts
        print("[OK] All stdlib expansion tests passed!")
    el ts
        print("[FAIL] " + str(failed) + " test(s) failed")
    Fin
Fin

main()