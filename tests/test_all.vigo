# ============================================
#   ViGo v3.5 Regression Test Suite
# ============================================

print("=== ViGo v3.5 Regression Test Suite ===")
print("")

state = { total: 0, errors: 0 }

Fun as check(name, condition):
    if condition ts
        print("  OK: " + name)
        state.total = state.total + 1
    el ts
        print("  FAIL: " + name)
        state.errors = state.errors + 1
        state.total = state.total + 1
    Fin
Fin

# ── 1. Switch multi-line case body ──
print("-- 1. Switch Multi-line Case --")

r1 = ""
x = 1
switch x ts
    case 1 ts
        r1 = "one"
Fin
check("switch single", r1 == "one")

r2 = ""
y = 2
switch y ts
    case 1 ts
        r2 = "one"
        r2 = r2 + "!"
    case 2 ts
        a2 = "two"
        r2 = a2 + "!"
Fin
check("switch multi-line", r2 == "two!")

r3 = ""
z = 10
switch z ts
    case 10 ts
        if ok ts
            r3 = "ten"
        Fin
Fin
check("switch nested if", r3 == "ten")

r4 = ""
score = 85
switch score ts
    case 90..100 ts
        r4 = "A"
    case 80..89 ts
        r4 = "B"
        r4 = r4 + "+"
    default ts
        r4 = "F"
Fin
check("switch range multi", r4 == "B+")

r5 = ""
marks = 50
switch marks ts
    case 100 ts
        r5 = "full"
    default ts
        r5 = "not full"
        r5 = r5 + " marks"
Fin
check("switch default multi", r5 == "not full marks")

r6 = ""
val = 42
switch val ts
    case 1 ts r6 = "one"
    case 2 ts r6 = "two"
    default ts
        r6 = "other"
Fin
check("switch fallthrough", r6 == "other")

# ── 2. Core language sanity ──
print("")
print("-- 2. Core Language --")

check("arithmetic", 2 + 3 * 4 == 14)
check("string concat", "hello" + " world" == "hello world")
check("bool ok", ok == ok)
check("bool no", no == no)
check("bool true", true == ok)
check("bool false", false == no)

r7 = 0
if 5 > 0 ts
    r7 = 1
Fin
check("if block", r7 == 1)

Fun as square(x):
    Ret x * x
Fin
check("function", square(4) == 16)

check("list comp", [x * x for x in 1..3] == [1, 4, 9])
#check("optional chain null", null?.name == null)
#check("null coalesce", null ?? "fallback" == "fallback")

const PI = 3.14159
check("const", PI == 3.14159)

# ── Summary ──
print("")
print("========================================")
print("Total: " + str(state.total))
print("Passed: " + str(state.total - state.errors))
print("Failed: " + str(state.errors))
if state.errors == 0 ts
    print("ALL TESTS PASSED!")
el ts
    print("SOME TESTS FAILED!")
Fin
print("========================================")