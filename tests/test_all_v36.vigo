# ============================================
#   ViGo v3.6 Full Regression Test Suite
# ============================================

print("=== ViGo v3.6 Full Regression Test ===")
print("")

state = { total: 0, errors: 0 }

Fun as check(name, condition):
    if condition ts
        print("  OK: " + name)
        state.total = state.total + 1
    el ts
        print("  FAIL: " + name)
        state.errors = state.errors + 1
        state.total = state.total + 1
    Fin
Fin

# ── 1. Variables ──
print("-- 1. Variables --")
a = 10
b = 20
check("addition", a + b == 30)

a, b, c = [1, 2, 3]
check("destructure", a == 1 and b == 2 and c == 3)

n = 5
n += 3
check("assign add", n == 8)

const PI = 3.14
check("const", PI == 3.14)

# ── 2. Data types ──
print("")
print("-- 2. Data types --")
arr = [1, 2, 3]
check("list index", arr[0] == 1)
check("list len", len(arr) == 3)

push(arr, 4)
check("push", len(arr) == 4)

obj = { name: "test", val: 42 }
check("dict dot", obj.name == "test")

s1 = {1, 2, 3}
s2 = {2, 3, 4}
check("set intersect", (s1 & s2) == {2, 3})

# ── 3. Operators ──
print("")
print("-- 3. Operators --")
check("div", 10 // 3 == 3)
check("pow", 2 ** 10 == 1024)
check("chain compare", (0 < 50 < 100) == ok)
check("ternary", (1 > 0 ? "yes" : "no") == "yes")
check("null coalesce", (null ?? "default") == "default")

# ── 4. Single-line if/loop ──
print("")
print("-- 4. Single-line --")
r1 = 0
if 1 < 2 ts
    r1 = 1
Fin
check("single if", r1 == 1)

r2 = 0
i2 = 0
loop i2 < 3 ts
    i2 = i2 + 1
Fin
check("single loop", i2 == 3)

# ── 5. Control flow ──
print("")
print("-- 5. Control flow --")
r3 = 0
for item in [10, 20, 30] ts
    r3 = r3 + item
Fin
check("for-in", r3 == 60)

r4 = 0
switch 3 ts
case 1 ts
    r4 = 1
case 3 ts
    r4 = 3
Fin
check("switch", r4 == 3)

r5 = 0
switch 85 ts
case 0..59 ts
    r5 = 1
case 80..100 ts
    r5 = 2
Fin
check("switch range", r5 == 2)

# ── 6. Functions ──
print("")
print("-- 6. Functions --")
Fun as add(a, b):
    Ret a + b
Fin
check("function", add(3, 4) == 7)

Fun as fib(n):
    if n <= 1 ts
        Ret n
    Fin
    Ret fib(n - 1) + fib(n - 2)
Fin
check("recursion", fib(10) == 55)

double = Fun x: x * 2 Fin
check("lambda", double(21) == 42)

# ── 7. Class ──
print("")
print("-- 7. Class --")
class Animal ts
    Fun as speak():
        Ret "sound"
    Fin
Fin
class Dog extends Animal ts
    Fun as speak():
        Ret "woof"
    Fin
Fin
d = new Dog()
check("class", d.speak() == "woof")

class MathHelper ts
    static Fun as square(x):
        Ret x * x
    Fin
Fin
check("static", MathHelper.square(5) == 25)

# ── 8. Exception ──
print("")
print("-- 8. Exception --")
r6 = ""
try ts
    throw "test"
catch e ts
    r6 = e
Fin
print("DEBUG r6: " + r6)
check("try-catch", r6 == "test")
sure 1 == 1
check("sure", ok)

# ── 9. Pipe ──
print("")
print("-- 9. Pipe --")
Fun as triple(x):
    Ret x * 3
Fin
r7 = [1, 2, 3] |> map(triple) |> sum
check("pipe", r7 == 18)

# ── 10. Types ──
print("")
print("-- 10. Types --")
check("type is number", type_is(42, "number") == ok)
check("type is string", type_is("hi", "string") == ok)
check("type of int", type_of(42) == "int")
check("type of string", type_of("hello") == "string")

# ── 11. Standard lib ──
print("")
print("-- 11. Stdlib --")
check("sqrt", sqrt(16) == 4.0)
check("abs", abs(-42) == 42)
check("md5 len", len(md5("hi")) == 32)
check("uuid len", len(uuid()) == 32)

j = to_json({ "test": 123 })
check("to_json", len(j) > 0)

check("replace", replace("cat", "c", "b") == "bat")
check("upper", upper("hi") == "HI")
check("trim", trim("  x  ") == "x")

r8 = random(1, 100)
check("random", r8 >= 1 and r8 <= 100)

check("date len", len(date()) == 10)

# ── 12. File ──
print("")
print("-- 12. File --")
write_file("_test.txt", "hello")
check("write", file_exists("_test.txt"))
check("read", read_file("_test.txt") == "hello")
remove_file("_test.txt")

# ── 13. Path ──
print("")
print("-- 13. Path --")
check("ext", path_ext("file.txt") == ".txt")
check("stem", path_stem("file.txt") == "file")

# ── 14. DB ──
print("")
print("-- 14. DB --")
db = db_open("_t.db")
db_execute(db, "CREATE TABLE IF NOT EXISTS t(x INT)")
db_execute(db, "INSERT INTO t VALUES(42)")
rows = db_query(db, "SELECT * FROM t")
check("db", len(rows) == 1)
db_close(db)
remove_file("_t.db")

# ── 15. Math ──
print("")
print("-- 15. Math --")
check("sin", sin(0) == 0.0)
check("cos", cos(0) == 1.0)
check("clamp", clamp(150, 0, 100) == 100)
check("PI val", PI >= 3.14)

# ── 16. AI ──
print("")
print("-- 16. AI --")
result = ai_ollama("Say one word: hello", "gemma-4b")
check("ai call", len(result) > 0)

stats = ai_stats()
check("token stats", stats["call_count"] > 0)

templates = prompt_list()
check("prompts", len(templates) > 0)

langs = i18n_languages()
check("i18n", len(langs) > 0)

check("cache", ai_enable_cache(true) == ok)

# ── Summary ──
print("")
print("========================================")
print("Total: " + str(state.total))
print("Passed: " + str(state.total - state.errors))
print("Failed: " + str(state.errors))
if state.errors == 0 ts
    print("ALL TESTS PASSED!")
el ts
    print("SOME TESTS FAILED!")
Fin
print("========================================")