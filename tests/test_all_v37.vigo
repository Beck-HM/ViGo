    # ═══════════════════════════════════════

    test26 = ok
    try ts
        Fun as factorial_tco(n, acc):
            if n <= 1 ts
                Ret acc
            Fin
            Ret factorial_tco(n - 1, n * acc)
        Fin
        result = factorial_tco(10, 1)
        test26 = result == 3628800 ? ok : no
        if result != 3628800 ts
            print("  Expected 3628800, got: " + str(result))
        Fin
    catch err ts
