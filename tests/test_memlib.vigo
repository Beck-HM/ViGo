# ============================================
#   Memory Library Test (v3.6 - RAG Edition)
# ============================================

print("=== Memory Library Test ===")
print("")

state = { total: 0, errors: 0 }

Fun as check(name, condition):
    if condition ts
        print("  OK: " + name)
        state.total = state.total + 1
    el ts
        print("  FAIL: " + name)
        state.errors = state.errors + 1
        state.total = state.total + 1
    Fin
Fin

# ── Basic CRUD ──
print("-- 1. Basic CRUD --")

check("mem_size start", mem_size() >= 0)

mem_save("name", "ViGo is an AI scripting language created by Beck")
check("mem_save + size", mem_size() >= 1)

result = mem_get("name")
check("mem_get exists", result != null)
check("mem_get key", result["key"] == "name")

check("mem_get missing", mem_get("nonexistent") == null)

check("mem_list", len(mem_list()) >= 1)

# ── Snapshot ──
print("")
print("-- 2. Snapshot --")

snap = mem_snapshot()
check("snapshot total", snap["total"] >= 1)
check("snapshot chromadb", snap["chromadb"] == ok)

# ── Forget ──
print("")
print("-- 3. Forget --")

size_before = mem_size()
mem_forget("name")
check("forget reduces size", mem_size() == size_before - 1)
check("forget gone", mem_get("name") == null)

# ── Clear ──
print("")
print("-- 4. Clear --")

mem_save("test", "temporary data")
mem_clear()
check("clear empty", mem_size() == 0)

# ── Summary ──
print("")
print("========================================")
print("Total: " + str(state.total))
print("Passed: " + str(state.total - state.errors))
print("Failed: " + str(state.errors))
if state.errors == 0 ts
    print("ALL TESTS PASSED!")
el ts
    print("SOME TESTS FAILED!")
Fin
print("========================================")