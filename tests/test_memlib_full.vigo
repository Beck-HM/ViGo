# ============================================
#   Memory Library - Full Feature Test
# ============================================

print("=== Memory Library Full Test ===")
print("")

state = { total: 0, errors: 0 }

Fun as check(name, condition):
    if condition ts
        print("  OK: " + name)
        state.total = state.total + 1
    el ts
        print("  FAIL: " + name)
        state.errors = state.errors + 1
        state.total = state.total + 1
    Fin
Fin

# Clean start
mem_clear()

# ── 1. Save + Fact Extraction ──
print("-- 1. Save with AI fact extraction --")

mem_save("vigo", "ViGo is a lightweight AI scripting language. It has 29 stdlib modules and supports 20 AI providers.")
vigo_data = mem_get("vigo")
check("mem_save works", vigo_data != null)
check("facts extracted", len(vigo_data["value"]) > 0)

mem_save("chromadb", "ChromaDB is an open-source vector database. It stores embeddings and enables semantic search.")
check("second save", mem_size() == 2)

# ── 2. Recall (semantic search) ──
print("")
print("-- 2. Semantic Recall --")

results = mem_recall("vector database", 5)
check("recall returns results", len(results) > 0)
check("chromadb ranked first", results[0]["key"] == "chromadb")
check("recall has similarity", results[0]["similarity"] > 0)

results2 = mem_recall("programming language", 5)
check("vigo ranked first for programming", results2[0]["key"] == "vigo")

# ── 3. Time-filtered Recall ──
print("")
print("-- 3. Time-filtered Recall --")

recent = mem_recall("database", 5, 24)
check("recent 24h has results", len(recent) > 0)

old = mem_recall("database", 5, 0)
check("0h filter returns empty", len(old) == 0)

# ── 4. Duplicate Detection + Merge ──
print("")
print("-- 4. Duplicate Detection --")

mem_save("vigo_v2", "ViGo now has 29 standard library modules and supports AI agents with memory")
mem_save("vigo_v3", "ViGo is an AI language with 29 stdlib modules, agents, and RAG")
check("merge keeps count stable", mem_size() <= 3)

# ── 5. Enhanced Ask ──
print("")
print("-- 5. Enhanced Ask --")

answer = mem_enhanced_ask("What is ViGo?", "gemma-4b", 3)
check("enhanced ask returns text", len(answer) > 0)
check("answer mentions ViGo", regex_match("(?i)vigo", answer) == ok)

# ── 6. Snapshot ──
print("")
print("-- 6. Snapshot --")

snap = mem_snapshot()
check("snapshot total", snap["total"] > 0)
check("snapshot has oldest", snap["oldest"] != null)
check("snapshot has newest", snap["newest"] != null)
check("chromadb active", snap["chromadb"] == ok)

# ── 7. Forget + Clear ──
print("")
print("-- 7. Cleanup --")

before = mem_size()
mem_forget("vigo")
check("forget one", mem_size() == before - 1)

mem_clear()
check("clear all", mem_size() == 0)

# ── Summary ──
print("")
print("========================================")
print("Total: " + str(state.total))
print("Passed: " + str(state.total - state.errors))
print("Failed: " + str(state.errors))
if state.errors == 0 ts
    print("ALL TESTS PASSED!")
el ts
    print("SOME TESTS FAILED!")
Fin
print("========================================")