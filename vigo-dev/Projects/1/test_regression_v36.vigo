# ============================================
#   ViGo v3.6 Full Regression Test Suite
#   Verified on: python main.py (dev build)
# ============================================

print("=== ViGo v3.6 Full Regression Test Suite ===")
print("")

state = { total: 0, errors: 0 }

Fun as check(name, condition):
    if condition ts
        print("  OK: " + name)
        state.total = state.total + 1
    el ts
        print("  FAIL: " + name)
        state.errors = state.errors + 1
        state.total = state.total + 1
    Fin
Fin


# ── 1. Variables ──
print("-- 1. Variables --")
a = 10
check("addition", a + 20 == 30)
a, b, c = [1, 2, 3]
check("destructure", a == 1 and b == 2 and c == 3)
n = 5
n += 3
check("assign add", n == 8)
const PI = 3.14159
check("const", PI == 3.14159)

# ── 2. Data Types ──
print("")
print("-- 2. Data Types --")
arr = [1, 2, 3]
check("list index", arr[0] == 1)
check("list len", len(arr) == 3)
push(arr, 4)
check("push", len(arr) == 4)
obj = { name: "test", val: 42 }
check("dict dot", obj.name == "test")
s1 = {1, 2, 3}
s2 = {2, 3, 4}
check("set intersect", (s1 & s2) == {2, 3})

# ── 3. Operators ──
print("")
print("-- 3. Operators --")
check("div", 10 // 3 == 3)
check("pow", 2 ** 10 == 1024)
check("ternary", (1 > 0 ? "yes" : "no") == "yes")
check("null coalesce", (null ?? "default") == "default")

# ── 4. Control Flow ──
print("")
print("-- 4. Control Flow --")
r1 = 0
if 1 < 2 ts
    r1 = 1
Fin
check("if block", r1 == 1)
r2 = 0
i2 = 0
loop i2 < 3 ts
    i2 = i2 + 1
Fin
check("loop while", i2 == 3)
r3 = 0
for item in [10, 20, 30] ts
    r3 = r3 + item
Fin
check("for-in", r3 == 60)
r5 = 0
go ts
    r5 = r5 + 1
Fin loop r5 < 3
check("go do-while", r5 == 3)

# ── 5. Functions ──
print("")
print("-- 5. Functions --")
Fun as addfn(a, b):
    Ret a + b
Fin
check("function", addfn(3, 4) == 7)

# ── 6. Exceptions ──
print("")
print("-- 6. Exceptions --")
e1 = ""
try ts
    throw "test-error"
catch err ts
    e1 = err
Fin
check("try-catch", e1 == "test-error")

# ── 7. Types ──
print("")
print("-- 7. Types --")
check("type is number", type_is(42, "number") == ok)
check("type is string", type_is("hi", "string") == ok)
check("type of int", type_of(42) == "int")

# ── 8. Stdlib ──
print("")
print("-- 8. Stdlib --")
check("sqrt", sqrt(16) == 4.0)
check("abs", abs(-42) == 42)
check("clamp", clamp(150, 0, 100) == 100)
check("sin", sin(0) == 0.0)
check("cos", cos(0) == 1.0)
check("md5 len", len(md5("hi")) == 32)
check("to_json", len(to_json({ "test": 123 })) > 0)
check("replace", replace("cat", "c", "b") == "bat")
check("upper", upper("hi") == "HI")
check("trim", trim("  x  ") == "x")
rnd = random(1, 100)
check("random", rnd >= 1 and rnd <= 100)
check("date len", len(date()) == 10)

# ── 9. File & Path ──
print("")
print("-- 9. File & Path --")
write_file("_t_reg.txt", "hello")
check("write", file_exists("_t_reg.txt"))
check("read", read_file("_t_reg.txt") == "hello")
remove_file("_t_reg.txt")
check("path ext", path_ext("file.txt") == ".txt")

# ── 10. DB ──
print("")
print("-- 10. DB --")
db = db_open("_t_reg.db")
db_execute(db, "CREATE TABLE IF NOT EXISTS t(x INT)")
db_execute(db, "INSERT INTO t VALUES(42)")
rows = db_query(db, "SELECT * FROM t")
check("db", len(rows) == 1)
db_close(db)
remove_file("_t_reg.db")

# ── 11. AI ──
print("")
print("-- 11. AI --")
providers = ai_list_providers()
check("ai providers", len(providers) > 0)
check("ai set key", ai_set_key("test-key") == ok)
check("ai cache", ai_enable_cache(ok) == ok)
check("ai clear cache", ai_clear_cache() == ok)
stats = ai_stats()
check("ai stats", stats != null)
check("ai set retries", ai_set_retries(3) == ok)
cfg = ai_get_retry_config()
check("ai retry config", cfg["max_retries"] == 3)
agent = ai_agent("gemma-4b", 2, no, "ollama")
check("ai agent", agent != null)
check("ai on chunk", ai_on_chunk(null) == ok)
chunks = ai_stream_chunks()
check("ai stream chunks empty", chunks == [])

# ── 12. Regex ──
print("")
print("-- 12. Regex --")
check("regex_test", regex_test("\\d+") == ok)
check("regex_match", regex_match("hello", "hello world") == ok)
check("regex_search", regex_search("\\d+", "abc 123 def") == "123")
check("regex_find_all", regex_find_all("\\d+", "1 2 3") == ["1", "2", "3"])
check("regex_replace", regex_replace("cat", "dog", "the cat") == "the dog")
check("regex_split", regex_split(",\\s*", "a, b, c") == ["a", "b", "c"])
check("regex_count", regex_count("\\d", "a1b2c3") == 3)

# ── 13. Markdown ──
print("")
print("-- 13. Markdown --")
md = "# Hello\n\n**bold** and *italic*"
check("md_to_html", len(md_to_html(md)) > 0)
check("md_to_html h1", regex_match("<h1>Hello</h1>", md_to_html(md)) == ok)
check("md_to_plain", regex_match("Hello", md_to_plain(md)) == ok)
check("md_count_words", md_count_words("hello world") == 2)
check("md_escape_html", md_escape_html("<a>") == "&lt;a&gt;")

# ── 14. HTML ──
print("")
print("-- 14. HTML --")
check("html_strip", html_strip("<p>Hi</p>") == "Hi")
check("html_count_tag", html_count_tag("<p><b>hi</b></p>", "b") == 1)
check("html_meta", html_meta("<meta name='desc' content='test'>", "desc") == "test")
check("html_title", html_title("<html><head><title>T</title></head></html>") == "T")

# ── 15. CSS ──
# ── 15. CSS ──
print("")
print("-- 15. CSS --")
check("css module", ok)

# ── Summary ──
print("")
print("========================================")
print("Total: " + str(state.total))
print("Passed: " + str(state.total - state.errors))
print("Failed: " + str(state.errors))
if state.errors == 0 ts
    print("ALL TESTS PASSED!")
el ts
    print("SOME TESTS FAILED!")
Fin
print("========================================")